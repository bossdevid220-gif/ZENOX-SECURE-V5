<!DOCTYPE html>
<html lang="EN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZENOX - CORE ADMIN PANEL</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family: system-ui, sans-serif; }
        body { background: #040209; color: #fff; padding: 30px; }
        .container { max-width: 900px; margin: 0 auto; }
        .header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 20px; border-bottom: 2px solid #FF0055; margin-bottom: 30px; }
        .header h1 { color: #FF0055; font-size: 24px; font-weight: 900; letter-spacing: 1px; }
        .nav-links a { background: rgba(0, 110, 255, 0.1); border: 1px solid #006EFF; color: #006EFF; padding: 8px 15px; border-radius: 8px; font-size: 12px; font-weight: 900; text-decoration: none; margin-left: 10px; }
        .nav-links .logout { border-color: #FF0055; color: #FF0055; background: rgba(255, 0, 85, 0.1); }
        .card { background: #0c0919; border-radius: 16px; padding: 25px; border: 1px solid rgba(255, 0, 85, 0.2); box-shadow: 0 5px 15px rgba(0,0,0,0.5); }
        h2 { color: #006EFF; font-size: 18px; font-weight: 900; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; background: rgba(255,255,255,0.02); border-radius: 10px; overflow: hidden; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid rgba(0, 110, 255, 0.1); }
        th { background: #006EFF; color: white; font-size: 12px; font-weight: 900; letter-spacing: 1px; }
        td { font-size: 14px; font-weight: bold; color: #adacb5; }
        .badge { background: #FF0055; color: white; padding: 3px 8px; font-size: 11px; border-radius: 5px; font-family: monospace; }
        .status-active { background: #00FF66; color: #000; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>ZENOX MAIN TERMINAL</h1>
        <div class="nav-links">
            <a href="/ZENOX-PORTAL-CORE-X92">📊 DASHBOARD</a>
            <a href="/ZENOX-TERMINATE" class="logout">🚪 LOGOUT</a>
        </div>
    </div>
    
    <div class="card">
        <h2>🛡️ SYSTEM USERS MANAGEMENT (TOTAL: <%= users.length %>)</h2>
        <table>
            <thead>
                <tr>
                    <th>DEVICE ID</th>
                    <th>ROLE</th>
                    <th>CREATED AT</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td><span class="badge"><%= user.deviceId %></span></td>
                        <td><%= user.role.toUpperCase() %></td>
                        <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<script>
    document.addEventListener('contextmenu', e => e.preventDefault());
</script>
</body>
</html>
