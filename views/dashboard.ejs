// REAL API SIMULATION - Gets actual result for a period
function getActualResult(periodId) {
    // Simulate actual number from API (0-9)
    const seed = parseInt(periodId.slice(-6)) || 1;
    const actualNum = (seed * 7 + 3) % 10;
    return actualNum;
}

function showTransitionPNG(oldPeriod) {
    const imgEl=document.getElementById('hackResultImg');
    if (!imgEl) return;
    resultPngShowing=true; imgEl.src=PNG_LOADING;
    _showLastResultChip('fetching');
    
    // Store current prediction for result processing
    const pred = shownPredictions[oldPeriod] || 'big';
    const predType = pred === 'big' ? 'BIG' : 'SMALL';
    const predNum = null; // We don't have number prediction in this flow
    
    setTimeout(()=>{
        // Get actual result from "API"
        const actualNum = getActualResult(oldPeriod);
        const actualType = actualNum >= 5 ? 'BIG' : 'SMALL';
        
        // Process result using REAL logic
        let resultStatus = '';
        if (predType === actualType) {
            resultStatus = 'WIN';
            hackWinRate = Math.min(100, hackWinRate + 2);
            if (hackLevel === 'L1') hackLevel = 'L2';
            else if (hackLevel === 'L2') hackLevel = 'L3';
        } else {
            resultStatus = 'LOSS';
            hackWinRate = Math.max(60, hackWinRate - 3);
            hackLevel = 'L1';
        }
        
        // Add to history with real data
        addHistoryEntry(oldPeriod, predType, actualNum, actualType, resultStatus);
        
        _showLastResultChip(resultStatus.toLowerCase());
        
        const winRateEl=document.getElementById('hackWinRateVal'), winRateChart=document.getElementById('hackWinRateChart');
        if (winRateEl) winRateEl.textContent=hackWinRate+'%';
        if (winRateChart) { const fill=Math.min(hackWinRate,100); winRateChart.style.background=`conic-gradient(#6c5ce7 0% ${fill}%,#2a2f55 ${fill}% 100%)`; }
        const lvlChart=document.getElementById('hackLvlChart'), lvlText=document.getElementById('hackLvlText'), lvlFill=getLevelFill();
        if (lvlChart) lvlChart.style.background=`conic-gradient(#6c5ce7 0% ${lvlFill}%,#2a2f55 ${lvlFill}% 100%)`;
        if (lvlText) lvlText.innerHTML=`<span class="target-icon"></span>${hackLevel}`;
        
        const {bigSmall,redGreen}=getCurrentPrediction();
        if (imgEl) imgEl.src=bigSmall==='big'?PNG_BIG:PNG_SMALL;
        const bsBadge=document.getElementById('hackBSBadge'), rgBadge=document.getElementById('hackRGBadge');
        if (bsBadge) { bsBadge.textContent=bigSmall==='big'?'⬆ BIG':'⬇ SMALL'; bsBadge.className='hack-pred-badge '+(bigSmall==='big'?'badge-big':'badge-small'); }
        if (rgBadge) { rgBadge.textContent=redGreen==='red'?'🔴 RED':'🟢 GREEN'; rgBadge.className='hack-pred-badge '+(redGreen==='red'?'badge-red':'badge-green'); }
        resultPngShowing=false;
    },3000);
}

