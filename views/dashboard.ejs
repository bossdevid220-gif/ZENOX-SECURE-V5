/* PERIOD & TIMER */
function getPeriodAndTimer() {
    const now = new Date();
    if (selectedPeriod === '1m') {
        const utcSeconds=now.getUTCSeconds(), utcMinutes=now.getUTCMinutes(), utcHours=now.getUTCHours();
        const remainingSeconds=60-utcSeconds;
        const totalMinutes=utcHours*60+utcMinutes;
        const dateStr=now.getUTCFullYear().toString()+String(now.getUTCMonth()+1).padStart(2,'0')+String(now.getUTCDate()).padStart(2,'0');
        const periodId=dateStr+'1000'+(10001+totalMinutes);
        return { periodId, remainingSeconds, totalSeconds:remainingSeconds };
    } else {
        const istOffset=5.5*60*60*1000, ist=new Date(now.getTime()+istOffset);
        const istH=ist.getUTCHours(), istM=ist.getUTCMinutes(), istS=ist.getUTCSeconds();
        let elapsed=(istH*3600+istM*60+istS)-(5*3600+30*60);
        if (elapsed<0) elapsed=0;
        const upcomingPeriod=Math.floor(elapsed/30)+1;
        const dateStr=ist.getUTCFullYear().toString()+String(ist.getUTCMonth()+1).padStart(2,'0')+String(ist.getUTCDate()).padStart(2,'0');
        const periodId=dateStr+'100005'+String(upcomingPeriod).padStart(4,'0');
        const remainingSeconds=30-(istS%30);
        return { periodId, remainingSeconds, totalSeconds:remainingSeconds };
    }
}

/* ============================================================
   PREDICTION ENGINE
============================================================ */
const _srvCache = {};

function _wangH(n) {
    n=((n^61)^(n>>>16))>>>0;
    n=(n+(n<<3))>>>0;
    n=(n^(n>>>4))>>>0;
    n=Math.imul(n,0x27d4eb2d)>>>0;
    n=(n^(n>>>15))>>>0;
    return n;
}
function _lcgH(n) {
    n=n>>>0;
    n=(Math.imul(n,1664525)+1013904223)>>>0;
    n=(Math.imul(n,1664525)+1013904223)>>>0;
    n=(Math.imul(n,1664525)+1013904223)>>>0;
    return n;
}
function _xorH(n) {
    n=n>>>0; n^=n<<13; n^=n>>17; n^=n<<5; return n>>>0;
}
function _fnvH(n) {
    let h=2166136261>>>0;
    for(let i=0;i<4;i++){h^=(n>>(i*8))&0xFF;h=Math.imul(h,16777619)>>>0;}
    return h;
}

function getServerPrediction(server,version,periodId) {
    const ck=server+':'+version+':'+periodId;
    if(_srvCache[ck]!==undefined) return _srvCache[ck];
    const seed=(parseInt(periodId.slice(-8))||1)>>>0;
    let h;
    switch(server){
        case 'ball': h=_wangH(seed^0xDEAD1234); break;
        case 'ultra':  h=_lcgH(seed^0xBEEF5678); break;
        case 'ai':    h=_fnvH(seed^0xCAFEBABE); break;
        default:      h=_xorH(seed^0xF00DBABE); break;
    }
    switch(version){
        case 'v1':   h=_xorH(h+1); break;
        case 'v2':   h=_lcgH(h+3); break;
        case 'ai':   h=_wangH(h+7); break;
        case 'calc': h=_fnvH(h+5); break;
        default: break;
    }
    const r=(h>>16)%2===0?'big':'small';
    _srvCache[ck]=r;
    const ks=Object.keys(_srvCache);
    if(ks.length>60) delete _srvCache[ks[0]];
    return r;
}

function getActiveServer() { return window._selectedServer||'ultra'; }
function getActiveVersion() { return window._selectedVersion||'v2'; }

function getCurrentPrediction() {
    const {periodId}=getPeriodAndTimer();
    const srv=getActiveServer(), ver=getActiveVersion();
    const bs=getServerPrediction(srv,ver,periodId);
    shownPredictions[periodId]=bs;
    const ks=Object.keys(shownPredictions);
    if(ks.length>15) delete shownPredictions[ks[0]];
    const rg=bs==='big'?'red':'green';
    return {bigSmall:bs,redGreen:rg,periodId,server:srv,version:ver};
}

function getConfidence() {
    const base=[65,72,58,80,51,70,63,76,55,68];
    const { periodId }=getPeriodAndTimer();
    return base[parseInt(periodId.slice(-2))%base.length];
}
function getLevelFill() { return hackLevel==='L1'?65:hackLevel==='L2'?35:20; }
function getTimerFill(rem,total) { return Math.round((rem/total)*100); }
function getPredictionImg() {
    const {bigSmall}=getCurrentPrediction();
    return bigSmall==='big'?PNG_BIG:PNG_SMALL;
}

