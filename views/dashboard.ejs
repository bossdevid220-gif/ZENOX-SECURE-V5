    // resultStatus: "WIN", "LOSS", or "JACKPOT"
    const entry = {
        period: period,
        prediction: prediction,
        actualNumber: actualNumber,
        actualType: actualType,
        status: resultStatus,
        timestamp: Date.now()
    };
    gameHistory.unshift(entry); // Latest at top
    if (gameHistory.length > 100) gameHistory.pop();
    localStorage.setItem('linuxGameHistory', JSON.stringify(gameHistory));
    renderHistoryTable();
}

function renderHistoryTable() {
    const tbody = document.getElementById('history-table-body');
    if (!tbody) return;
    
    if (gameHistory.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:#7a7aaa;font-weight:600;padding:20px;">NO HISTORY YET</td></tr>';
        return;
    }
    
    let html = '';
    gameHistory.slice(0, 30).forEach(item => {
        // Status class for styling
        const statusClass = item.status.toLowerCase(); // 'win', 'loss', 'jackpot'
        
        // Prediction badge class
        let badgeClass = 'big';
        let displayPred = item.prediction;
        if (item.prediction === 'SMALL' || item.prediction === 'S') { badgeClass = 'small'; }
        else if (item.prediction === 'RED') { badgeClass = 'red'; }
        else if (item.prediction === 'GREEN') { badgeClass = 'green'; }
        else if (item.prediction === 'JACKPOT') { badgeClass = 'jackpot'; }
        else if (!isNaN(item.prediction) && item.prediction !== '') { badgeClass = 'number'; }
        
        // Result display
        let resultDisplay = item.actualNumber + ' (' + item.actualType + ')';
        
        // Status display with emoji
        let statusDisplay = item.status;
        if (item.status === 'WIN') statusDisplay = '✅ WIN';
        else if (item.status === 'LOSS') statusDisplay = '❌ LOSS';
        else if (item.status === 'JACKPOT') statusDisplay = '🎰 JACKPOT';
        
        // Period display (last 6 digits)
        const periodDisplay = String(item.period).slice(-6);
        
        html += `<tr>
            <td style="font-weight:700;font-family:'Orbitron',sans-serif;font-size:11px;color:#8b5cf6;">${periodDisplay}</td>
            <td><span class="result-badge ${badgeClass}">${displayPred}</span></td>
            <td style="font-weight:600;">${resultDisplay}</td>
            <td class="${statusClass}" style="font-weight:800;font-size:12px;">${statusDisplay}</td>
        </tr>`;
    });
    tbody.innerHTML = html;
}

function clearAllHistory() {
    if (gameHistory.length === 0) { showToast('NO HISTORY TO CLEAR'); return; }
    if (confirm('ARE YOU SURE YOU WANT TO CLEAR ALL HISTORY?')) {
        gameHistory = [];
        localStorage.setItem('linuxGameHistory', JSON.stringify(gameHistory));
        renderHistoryTable();
        showToast('✅ HISTORY CLEARED');
    }
}

// ============================================================
// REAL PREDICTION RESULT LOGIC - Called when round completes
// ============================================================
function processRoundResult(period, predictedType, predictedNumber, actualNumber) {
    // Determine actual type (Big/Small)
    let actualType = '';
    if (actualNumber >= 5) actualType = 'BIG';
    else if (actualNumber >= 0) actualType = 'SMALL';
    else actualType = 'UNKNOWN';
    
    let resultStatus = '';
    
    // JACKPOT: If predicted number matches actual number
    if (predictedNumber !== null && predictedNumber === actualNumber) {
        resultStatus = 'JACKPOT';
    } 
    // WIN: If predicted type matches actual type
    else if (predictedType === actualType) {
        resultStatus = 'WIN';
    } 
    // LOSS: No match
    else {
        resultStatus = 'LOSS';
    }
    
    // Add to history
    addHistoryEntry(period, predictedType, actualNumber, actualType, resultStatus);
    
    // Return result for UI feedback
    return { resultStatus, actualType, actualNumber };
}

