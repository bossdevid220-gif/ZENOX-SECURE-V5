<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>LINUX PREDICTOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@700;900&family=Grandstander:ital,wght@0,100..900;1,100..900&family=Poppins:wght@400;500;600;700;800;900&family=Nunito:wght@500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin:0;padding:0;box-sizing:border-box;font-family:'Grandstander','Poppins','Nunito','Inter',sans-serif;-webkit-tap-highlight-color:transparent; }
        html,body { height:100%;width:100%;background-color:#0b0e1a;display:flex;justify-content:center;overflow:hidden; }
        .app-container { width:100%;max-width:480px;height:100%;height:100dvh;background:#0f1322;position:relative;display:flex;flex-direction:column;box-shadow:0 0 30px rgba(80,70,200,0.12);overflow:hidden; }
        @media (max-width:480px) { .app-container { max-width:100%;box-shadow:none; } }

        :root { --primary:#6c5ce7; --dark:#3d2f9e; --blue:#4a6cf7; --violet:#8b5cf6; --white:#ffffff; --light-bg:#161b33; --card-bg:#1a1f3a; --border-glow:rgba(108,92,231,0.3); --text-primary:#e8e6ff; --text-secondary:#a8a4d4; --shadow-glow:0 8px 32px rgba(74,108,247,0.15); }

        .page { position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;transition:transform 0.35s cubic-bezier(0.4,0,0.2,1),opacity 0.35s ease;will-change:transform; }
        #main-page { transform:translateX(0);z-index:1;visibility:visible; }
        #main-page.slide-out { transform:translateX(-100%); }
        #webview-page { transform:translateX(100%);z-index:2;background:#0f1322; }
        #webview-page.slide-in { transform:translateX(0); }
        .content-area { flex:1;overflow-y:auto;overflow-x:hidden;scrollbar-width:none;position:relative;background:#0f1322; }
        .content-area::-webkit-scrollbar { display:none; }
        .tab-panel { display:none;width:100%;min-height:100%;padding-bottom:10px; }
        .tab-panel.active { display:block; }

        .bottom-nav { display:flex;justify-content:space-around;align-items:center;background:#161b33;border-top:1.5px solid #2a2f55;padding:8px 0 calc(8px + env(safe-area-inset-bottom));flex-shrink:0;box-shadow:0 -4px 24px rgba(74,108,247,0.06);z-index:100; }
        .nav-item { display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;padding:4px 18px;border-radius:14px;transition:background 0.18s;user-select:none; }
        .nav-item:active { background:rgba(108,92,231,0.10); }
        .nav-text { font-size:11px;font-weight:700;color:#6a6a8a;letter-spacing:0.2px;transition:color 0.2s;text-transform:uppercase; }
        .nav-icon-wrapper { display:flex;align-items:center;justify-content:center; }
        .nav-item:not(.active) svg [fill="#6c5ce7"],.nav-item:not(.active) svg [fill="#1c1c1e"] { fill:#4a4a6a; }
        .nav-item:not(.active) svg [stroke="white"] { stroke:#2a2f55; }
        .nav-item:not(.active) svg circle[fill="white"],.nav-item:not(.active) svg rect[fill="white"] { fill:#2a2f55; }
        .nav-item.active .nav-text { color:#8b5cf6; }
        .nav-item.active svg [fill="#6c5ce7"],.nav-item.active svg [fill="#1c1c1e"] { fill:#8b5cf6; }
        .nav-item.active svg [stroke="white"] { stroke:#ffffff; }
        .nav-item.active svg circle[fill="white"],.nav-item.active svg rect[fill="white"] { fill:#ffffff; }

        #tab-home { background:#0f1322;padding:20px 16px; }
        .home-header { display:flex;align-items:center;margin-bottom:24px;padding-left:4px; }
        .avatar { width:48px;height:48px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2px solid #6c5ce7;box-shadow:0 0 20px rgba(108,92,231,0.2);background:#161b33;display:flex;align-items:center;justify-content:center; }
        .avatar img { width:100%;height:100%;object-fit:cover; }
        .user-info { display:flex;flex-direction:column;margin-left:14px; }
        .welcome-text { font-size:12px;color:#7a7aaa;font-weight:600;letter-spacing:0.3px;text-transform:uppercase; }
        .user-name { font-size:17px;font-weight:800;color:#e8e6ff;text-transform:uppercase;letter-spacing:0.8px; }
        .main-card { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:24px;padding:32px 20px;display:flex;flex-direction:column;align-items:center;text-align:center;box-shadow:var(--shadow-glow);margin-bottom:20px;border:1px solid #2a2f55; }
        .logo-wrapper { position:relative;width:170px;height:100px;border-radius:14px;overflow:hidden;display:flex;justify-content:center;align-items:center;margin-bottom:22px;background:#0f1322; }
        .logo-wrapper::before { content:'';position:absolute;width:200%;height:200%;background:conic-gradient(from 0deg,transparent 75%,#6c5ce7 100%);animation:rotate-snake 2.8s linear infinite; }
        .logo-wrapper img { width:calc(100% - 6px);height:calc(100% - 6px);object-fit:contain;border-radius:10px;position:relative;z-index:1;background:#0f1322;padding:4px; }
        @keyframes rotate-snake { 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }
        .main-card h1 { color:#e8e6ff;font-size:24px;font-weight:800;margin-bottom:10px;letter-spacing:1px; }
        .main-card p { color:#a8a4d4;font-size:14px;line-height:1.6;margin-bottom:22px;padding:0 6px;font-weight:500; }
        .badge { background:linear-gradient(145deg,#6c5ce7,#4a6cf7);color:#fff;padding:10px 22px;border-radius:40px;font-size:13px;font-weight:800;display:inline-flex;align-items:center;gap:8px;letter-spacing:0.8px;box-shadow:0 4px 16px rgba(108,92,231,0.3); }
        .badge svg { width:16px;height:16px;fill:currentColor; }
        .grid-container { display:grid;grid-template-columns:1fr 1fr;gap:16px; }
        .grid-card { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:22px;padding:24px 16px;box-shadow:var(--shadow-glow);display:flex;flex-direction:column;align-items:flex-start;cursor:pointer;transition:transform 0.15s, box-shadow 0.2s;border:1px solid #2a2f55; }
        .grid-card:active { transform:scale(0.96);box-shadow:0 4px 16px rgba(74,108,247,0.08); }
        .grid-card svg { width:28px;height:28px;fill:#8b5cf6;margin-bottom:14px; }
        .grid-card h3 { color:#e8e6ff;font-size:16px;font-weight:800;margin-bottom:4px;letter-spacing:0.3px;text-transform:uppercase; }
        .grid-card p { color:#a8a4d4;font-size:12px;line-height:1.4;font-weight:600;text-transform:uppercase; }

        /* HISTORY TAB */
        #tab-plan { background:#0f1322;display:none;flex-direction:column;min-height:100%; }
        #tab-plan.active { display:flex; }
        .plan-header { padding:22px 20px 10px;display:flex;align-items:center;gap:14px; }
        .plan-profile-icon { width:48px;height:48px;border-radius:50%;overflow:hidden;border:2px solid #6c5ce7;flex-shrink:0;background:#161b33;display:flex;align-items:center;justify-content:center; }
        .plan-profile-icon img { width:100%;height:100%;object-fit:cover; }
        .plan-profile-text { display:flex;flex-direction:column; }
        .plan-welcome { font-size:12px;color:#7a7aaa;font-weight:700;letter-spacing:0.4px;text-transform:uppercase; }
        .plan-name { font-size:17px;color:#e8e6ff;font-weight:900;text-transform:uppercase;letter-spacing:0.8px; }
        .plan-main { flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 0 20px;width:100%; }
        .animated-logo-wrapper { position:relative;width:170px;height:95px;margin-bottom:24px;border-radius:16px;display:flex;justify-content:center;align-items:center;overflow:hidden; }
        .animated-logo-wrapper::before { content:'';position:absolute;width:260px;height:260px;background:conic-gradient(transparent,transparent,transparent,#6c5ce7);animation:rotateBorder 2.8s linear infinite; }
        .animated-logo-wrapper::after { content:'';position:absolute;inset:3px;background:#0f1322;border-radius:13px; }
        .animated-logo-wrapper img { position:relative;z-index:10;width:calc(100% - 6px);height:calc(100% - 6px);object-fit:contain;border-radius:12px;background:#0f1322;padding:4px; }
        @keyframes rotateBorder { 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }
        .plan-title { font-size:24px;font-weight:900;color:#e8e6ff;margin-bottom:8px;letter-spacing:1px;text-transform:uppercase; }
        .plan-subtitle { font-size:13px;color:#a8a4d4;font-weight:600;text-align:center;padding:0 30px;line-height:1.6;margin-bottom:20px;text-transform:uppercase; }

        /* HISTORY TABLE - Clean design */
        .history-container { width:100%;padding:0 16px 20px; }
        .history-header { display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding:0 4px; }
        .history-header h3 { color:#e8e6ff;font-size:18px;font-weight:900;text-transform:uppercase;letter-spacing:0.5px; }
        .clear-history-btn { background:linear-gradient(145deg,#e74c3c,#c0392b);color:white;border:none;padding:8px 18px;border-radius:30px;font-size:12px;font-weight:800;cursor:pointer;text-transform:uppercase;transition:0.2s;box-shadow:0 4px 12px rgba(231,76,60,0.15); }
        .clear-history-btn:active { transform:scale(0.94);opacity:0.8; }
        .history-table-wrap { width:100%;overflow-x:auto;margin-top:4px; }
        .history-table { width:100%;border-collapse:collapse;font-size:12px; }
        .history-table th { text-align:left;color:#7a7aaa;font-weight:800;text-transform:uppercase;letter-spacing:0.5px;padding:10px 12px;border-bottom:1px solid #2a2f55;font-size:10px; }
        .history-table td { padding:12px 12px;border-bottom:1px solid #1a1f3a;color:#e8e6ff;font-weight:600; }
        .history-table tr:last-child td { border-bottom:none; }
        
        /* Result Badges */
        .result-badge { display:inline-block;padding:4px 16px;border-radius:20px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.5px; }
        .result-badge.big { background:linear-gradient(145deg,#6c5ce7,#4a6cf7);color:#fff; }
        .result-badge.small { background:linear-gradient(145deg,#f59e0b,#d97706);color:#fff; }
        .result-badge.red { background:linear-gradient(145deg,#e74c3c,#c0392b);color:#fff; }
        .result-badge.green { background:linear-gradient(145deg,#6c5ce7,#4a6cf7);color:#fff; }
        .result-badge.jackpot { background:linear-gradient(145deg,#f59e0b,#eab308);color:#fff; }
        .result-badge.number { background:linear-gradient(145deg,#4a6cf7,#3d2f9e);color:#fff; }
        
        /* Status Colors */
        .win { color:#6c5ce7;font-weight:800; }
        .loss { color:#e74c3c;font-weight:800; }
        .jackpot { color:#f59e0b;font-weight:800; }
        .history-empty { color:#7a7aaa;font-size:14px;font-weight:700;text-align:center;padding:30px 0;text-transform:uppercase; }

        /* PROFILE */
        #tab-profile { background:#0f1322;padding:20px; }
        .profile-card-box { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:24px;padding:28px 20px;margin-bottom:18px;box-shadow:var(--shadow-glow);text-align:center;border:1px solid #2a2f55; }
        .prof-logo-wrapper { position:relative;width:190px;height:105px;margin:0 auto 18px auto;border-radius:14px;display:flex;justify-content:center;align-items:center;overflow:hidden;background:#0f1322; }
        .prof-logo-wrapper::before { content:'';position:absolute;width:320px;height:320px;background:conic-gradient(transparent,transparent,transparent,#6c5ce7);animation:rotateBorder 2.4s linear infinite; }
        .prof-logo-wrapper::after { content:'';position:absolute;inset:3px;background:#0f1322;border-radius:11px; }
        .prof-logo-wrapper img { position:relative;z-index:10;width:calc(100% - 6px);height:calc(100% - 6px);object-fit:contain;border-radius:10px;background:#0f1322;padding:4px; }
        .prof-avatar-wrap { position:relative;width:88px;height:88px;margin:0 auto 14px auto; }
        .prof-avatar-circle { width:88px;height:88px;border-radius:50%;overflow:hidden;border:3px solid #6c5ce7;box-shadow:0 0 24px rgba(108,92,231,0.15);background:#161b33;display:flex;align-items:center;justify-content:center; }
        .prof-avatar-circle img { width:100%;height:100%;object-fit:cover; }
        .profile-name-text { font-size:22px;font-weight:900;color:#e8e6ff;margin-bottom:2px;letter-spacing:0.5px;text-transform:uppercase; }
        .profile-email-text { font-size:14px;color:#a8a4d4;font-weight:600;margin-bottom:16px;text-transform:uppercase; }
        .plan-badge-prof { background:linear-gradient(145deg,#6c5ce7,#4a6cf7);color:white;padding:8px 22px;border-radius:40px;display:inline-flex;align-items:center;font-size:14px;font-weight:800;gap:10px;box-shadow:0 4px 16px rgba(108,92,231,0.25);text-transform:uppercase; }
        .details-card-box { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:24px;padding:6px 20px;margin-bottom:18px;box-shadow:var(--shadow-glow);border:1px solid #2a2f55; }
        .list-item { display:flex;align-items:center;padding:16px 0;border-bottom:1.5px solid #2a2f55; }
        .list-item:last-child { border-bottom:none; }
        .icon-box { background:#2a2f55;width:44px;height:44px;border-radius:14px;display:flex;justify-content:center;align-items:center;color:#8b5cf6;font-size:18px; }
        .item-text { margin-left:16px;display:flex;flex-direction:column; }
        .item-label { font-size:11px;color:#7a7aaa;font-weight:800;text-transform:uppercase;letter-spacing:0.6px; }
        .item-value { font-size:15px;color:#e8e6ff;font-weight:800;margin-top:2px;text-transform:uppercase; }
        .logout-btn { width:100%;background:linear-gradient(145deg,#e74c3c,#c0392b);color:white;border:none;padding:18px;border-radius:16px;font-size:17px;font-weight:800;cursor:pointer;margin-bottom:18px;display:flex;justify-content:center;align-items:center;gap:12px;box-shadow:0 6px 20px rgba(231,76,60,0.2);font-family:'Grandstander','Nunito',sans-serif;transition:all 0.2s;text-transform:uppercase; }
        .logout-btn:active { transform:scale(0.96);opacity:0.9; }
        .legal-card-box { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:24px;padding:26px 20px;margin-bottom:10px;box-shadow:var(--shadow-glow);border:1px solid #2a2f55; }
        .section-title-legal { font-size:14px;color:#e8e6ff;font-weight:800;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:10px;letter-spacing:0.8px; }
        .legal-block { margin-bottom:22px; }
        .legal-block:last-child { margin-bottom:0; }
        .legal-block h4 { font-size:15px;color:#e8e6ff;font-weight:800;display:flex;align-items:center;gap:8px;margin-bottom:6px;text-transform:uppercase; }
        .legal-block p { font-size:13px;color:#a8a4d4;line-height:1.7;font-weight:600; }
        .telegram-link { color:#8b5cf6!important;font-weight:800!important;margin-top:6px;display:flex;align-items:center;gap:6px; }

        /* GAMES */
        #tab-games { background:#0f1322;padding:20px; }
        .game-header { display:flex;align-items:center;gap:14px;margin-bottom:24px; }
        .game-profile-icon { width:48px;height:48px;border-radius:50%;overflow:hidden;border:2px solid #6c5ce7;flex-shrink:0;background:#161b33;display:flex;align-items:center;justify-content:center; }
        .game-profile-icon img { width:100%;height:100%;object-fit:cover; }
        .game-profile-text { display:flex;flex-direction:column;margin-left:0; }
        .game-welcome { font-size:12px;color:#7a7aaa;font-weight:700;letter-spacing:0.3px;text-transform:uppercase; }
        .game-name { font-size:17px;color:#e8e6ff;font-weight:900;text-transform:uppercase;letter-spacing:0.8px; }
        .predictor-banner { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:24px;padding:22px 20px;display:flex;align-items:center;gap:18px;margin-bottom:28px;box-shadow:var(--shadow-glow);border:1px solid #2a2f55; }
        .banner-logo { width:56px;height:56px;object-fit:contain;flex-shrink:0; }
        .banner-text h2 { font-size:22px;font-weight:900;color:#e8e6ff;margin-bottom:2px;letter-spacing:0.5px;text-transform:uppercase; }
        .banner-text p { font-size:13px;color:#a8a4d4;font-weight:600;text-transform:uppercase; }
        .section-label-game { font-size:12px;color:#7a7aaa;font-weight:900;letter-spacing:1.5px;margin-bottom:14px;text-transform:uppercase; }
        .game-types { display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px; }
        .game-card-item { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:22px;padding:28px 16px;text-align:center;cursor:pointer;border:2px solid #2a2f55;transition:all 0.25s;box-shadow:var(--shadow-glow); }
        .game-card-item.active { border-color:#8b5cf6;background:linear-gradient(145deg,#1e2350,#161b3a);box-shadow:0 8px 24px rgba(108,92,231,0.08); }
        .game-badge-icon { width:52px;height:52px;margin:0 auto 16px auto;border-radius:50%;display:flex;justify-content:center;align-items:center;color:white;font-size:20px; }
        .badge-green-g { background:linear-gradient(145deg,#6c5ce7,#4a6cf7);clip-path:polygon(50% 0%,61% 8%,75% 5%,80% 19%,95% 25%,92% 40%,100% 50%,92% 60%,95% 75%,80% 81%,75% 95%,61% 92%,50% 100%,39% 92%,25% 95%,20% 81%,5% 75%,8% 60%,0% 50%,8% 40%,5% 25%,20% 19%,25% 5%,39% 8%); }
        .badge-dark-g { background:linear-gradient(145deg,#4a6cf7,#3d2f9e);clip-path:polygon(50% 0%,61% 8%,75% 5%,80% 19%,95% 25%,92% 40%,100% 50%,92% 60%,95% 75%,80% 81%,75% 95%,61% 92%,50% 100%,39% 92%,25% 95%,20% 81%,5% 75%,8% 60%,0% 50%,8% 40%,5% 25%,20% 19%,25% 5%,39% 8%); }
        .game-card-item h3 { font-size:16px;font-weight:900;color:#e8e6ff;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px; }
        .game-card-item p { font-size:12px;color:#a8a4d4;font-weight:700;text-transform:uppercase; }
        .hidden-section { display:none; }
        .period-card { background:linear-gradient(145deg,#1a1f3a,#14192e);border-radius:22px;padding:18px 20px;display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;box-shadow:var(--shadow-glow);border:1px solid #2a2f55; }
        .period-left { display:flex;align-items:center;gap:16px; }
        .clock-icon { width:44px;height:44px;background:#2a2f55;border-radius:14px;display:flex;justify-content:center;align-items:center; }
        .clock-icon svg { width:22px;height:22px;stroke:#8b5cf6;stroke-width:2.2; }
        .period-label { font-size:16px;font-weight:900;color:#e8e6ff;letter-spacing:0.5px;text-transform:uppercase; }
        .period-selector { background:linear-gradient(145deg,#6c5ce7,#4a6cf7);color:white;padding:12px 22px;border-radius:40px;font-size:14px;font-weight:900;cursor:pointer;display:flex;align-items:center;gap:10px;user-select:none;transition:all 0.2s;box-shadow:0 4px 16px rgba(108,92,231,0.2);text-transform:uppercase; }
        .period-selector:active { transform:scale(0.94); }
        .connect-row { display:flex;gap:12px;margin-bottom:20px; }
        .connect-input { flex:1;background:#1a1f3a;border:2px solid #2a2f55;border-radius:20px;padding:18px 22px;font-size:15px;font-weight:700;color:#e8e6ff;outline:none;box-shadow:var(--shadow-glow);transition:border-color 0.3s;font-family:'Grandstander','Nunito',sans-serif;text-transform:uppercase; }
        .connect-input:focus { border-color:#8b5cf6; }
        .connect-input::placeholder { color:#6a6a8a;font-weight:600;text-transform:uppercase; }
        .connect-btn { background:linear-gradient(145deg,#6c5ce7,#4a6cf7);color:white;border:none;border-radius:20px;padding:0 30px;font-size:16px;font-weight:900;cursor:pointer;box-shadow:0 6px 20px rgba(108,92,231,0.25);transition:transform 0.2s,background-color 0.2s;font-family:'Grandstander','Nunito',sans-serif;white-space:nowrap;text-transform:uppercase; }
        .connect-btn:active { transform:scale(0.94);opacity:0.9; }
        .connect-btn.connected { background:linear-gradient(145deg,#4a6cf7,#3d2f9e); }
        @keyframes slideDown { from{opacity:0;transform:translateY(-14px)} to{opacity:1;transform:translateY(0)} }
        .animate-in { animation:slideDown 0.4s ease forwards; }

        /* WEBVIEW */
        #webview-page { background-color:#0f1322; }
        .wv-header { display:flex;align-items:center;padding:16px 20px;background:#161b33;box-shadow:0 2px 16px rgba(0,0,0,0.2);z-index:10;flex-shrink:0;border-bottom:1px solid #2a2f55; }
        .wv-back-btn { background:none;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;margin-right:18px;color:#e8e6ff; }
        .wv-back-btn svg { width:26px;height:26px;fill:currentColor; }
        .wv-logo-container { width:44px;height:44px;border-radius:50%;background:#2a2f55;display:flex;align-items:center;justify-content:center;overflow:hidden;margin-right:16px;border:2px solid #6c5ce7; }
        .wv-logo-container img { width:100%;height:100%;object-fit:contain;padding:2px; }
        .wv-header-title { font-size:17px;font-weight:900;color:#e8e6ff;letter-spacing:0.5px;text-transform:uppercase; }
        .wv-main-content { flex:1;background:#0f1322;position:relative;overflow:hidden;min-height:0; }
        .wv-main-content iframe { width:100%;height:100%;border:none;display:block; }
        .wv-fab-container { position:absolute;bottom:22px;left:50%;transform:translateX(-50%);z-index:210;transition:all 0.3s; }
