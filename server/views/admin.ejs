<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADMIN PANEL</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            background: #0a0618;
            font-family: system-ui, sans-serif;
            color: #fff;
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 800px; margin: 0 auto; }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid rgba(139,92,246,0.2);
            margin-bottom: 24px;
        }
        .header h1 { color: #8B5CF6; font-size: 20px; font-weight: 900; }
        .logout-btn {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.2);
            color: #ef4444;
            padding: 6px 16px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
        }
        .card {
            background: #1a0a3e;
            border-radius: 16px;
            padding: 24px;
            border: 1px solid rgba(139,92,246,0.1);
            margin-bottom: 16px;
        }
        .card h2 { color: #8B5CF6; font-size: 16px; margin-bottom: 16px; }
        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        th { text-align: left; padding: 10px 8px; color: #7c6ba0; border-bottom: 1px solid rgba(139,92,246,0.1); }
        td { padding: 10px 8px; border-bottom: 1px solid rgba(139,92,246,0.05); color: #d4d0e0; }
        .status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; }
        .status-dot.active { background: #10b981; }
        .status-dot.inactive { background: #ef4444; }
        .btn {
            padding: 4px 12px;
            border-radius: 6px;
            border: none;
            font-size: 11px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-warning { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
        .btn-warning:hover { background: rgba(245,158,11,0.25); }
        .btn-danger { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
        .btn-danger:hover { background: rgba(239,68,68,0.25); }
        .footer { text-align: center; padding: 20px 0; font-size: 11px; color: #3d2d5a; }
        .empty { text-align: center; color: #5b4a7a; padding: 20px; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>⚙ ADMIN PANEL</h1>
        <a href="/logout" class="logout-btn">🚪 LOGOUT</a>
    </div>
    
    <div class="card">
        <h2>👥 REGISTERED USERS</h2>
        <% if (users && users.length > 0) { %>
            <table>
                <thead>
                    <tr><th>DEVICE ID</th><th>ROLE</th><th>STATUS</th><th>LAST LOGIN</th><th>ACTIONS</th></tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td style="font-family:monospace;font-size:12px;"><%= user.deviceId %></td>
                            <td><%= user.role %></td>
                            <td>
                                <span class="status-dot <%= user.isActive ? 'active' : 'inactive' %>"></span>
                                <%= user.isActive ? 'ACTIVE' : 'DISABLED' %>
                            </td>
                            <td style="font-size:12px;color:#7c6ba0;"><%= user.lastLogin ? new Date(user.lastLogin).toLocaleString() : 'NEVER' %></td>
                            <td>
                                <form action="/admin/user/<%= user._id %>/toggle" method="POST" style="display:inline;">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="btn btn-warning"><%= user.isActive ? 'DISABLE' : 'ENABLE' %></button>
                                </form>
                                <form action="/admin/user/<%= user._id %>/delete" method="POST" style="display:inline;">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="btn btn-danger" onclick="return confirm('DELETE THIS USER?')">DELETE</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p class="empty">NO USERS REGISTERED YET.</p>
        <% } %>
    </div>
    
    <div class="footer">UNBREAKABLE V1.0</div>
</div>
</body>
</html>
